@startuml write_claims_vn
title /write_claims/ — 청구항 생성 플로우
skinparam DefaultFontName "Noto Sans KR"
skinparam ActivityFontSize 13
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #E0A800
skinparam ActivityBorderColor #5B8CFF
skinparam ActivityBackgroundColor #EEF3FF
skinparam ArrowColor #333

|입력|
start
:발명 텍스트 (str / dict);

|#EEF3FF|청구항 생성|

partition "Prompt 1 — Composition Prompt" {
  :입력: {invention}
   함수: parse_claim_invention()
   모델: gpt-5.2
   역할: 발명 텍스트에서 구성요소·목적·효과 파싱;
}

partition "Prompt 2 — Avoidance Strategy" {
  :입력: {similar_patents_text}, {text}
   함수: generate_claims(prompt1)
   모델: gpt-4o-2024-08-06
   역할: 유사특허 분석 → 회피전략 + 새 발명 개요 도출;
}

partition "Prompt 3 — Claims Generation" {
  :입력: {text}, {response_prompt}←P2출력
   함수: generate_claims(prompt2)
   모델: gpt-4o-2024-08-06
   역할: 독립항 1개 + 종속항 N-1개 생성 (few-shot 포함);
}
note right
  few-shot: prompt2에 하드코딩된 2건
  ① AI 연속공정 제어 장치 (물건 발명)
  ② 기능성 조성물 제조방법 (방법 발명)
end note

partition "Prompt 5 — Refine Claims" {
  :입력: {response2}←P3출력
   함수: generate_claims(prompt3)
   모델: gpt-4o-2024-08-06
   역할: KIPO 심사기준에 맞게 청구항 정제
         명확성·선행사·카테고리 통일;
}

|출력|
:최종 청구항 반환
【청구항 1】…【청구항 N】;
stop
@enduml


@startuml write_specification_vn
title /write_specification/all_exclude — 명세서 전체 생성 플로우 (vN)
skinparam DefaultFontName "Noto Sans KR"
skinparam ActivityFontSize 13
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #E0A800
skinparam ActivityBorderColor #3AD6A0
skinparam ActivityBackgroundColor #EFF9F5
skinparam ArrowColor #333
skinparam PartitionBorderColor #3AD6A0
skinparam PartitionBackgroundColor #F0FAF6

|입력|
start
:청구항 텍스트 입력
【청구항 1】…【청구항 N】
(독립항 + 종속항 전체 / ¶ 구분);

|#EFF9F5|명세서 생성|

partition "CPC 분류 (yaml 외 별도)" {
  :입력: 청구항 텍스트
   함수: get_cpc_chatgpt()
   모델: gpt-4o-mini
   역할: 청구항 → CPC 코드 1개 분류
         → 전개앵커 결정에 사용;
}

partition "Prompt 6 — Spec Generation  〔병렬〕" {
  :입력: {text}, {prefix_name}, {prefix}, {example}
   함수: get_specification_chatgpt()
   모델: gpt-5.2
   역할: 명세서 섹션 9종 생성
         Title·TF·BG·Problem·Solution·Effects·Summary·prior_patent;
}
note right
  prior_patent 처리 시 내부 호출:
  Prompt 4 — Claims Summary
  입력: {text}←선행특허 청구항
  역할: 청구항 요약·목적·설명 추출
end note

if (도면 있음?) then (yes)
  partition "Prompt 9 — Drawing Description" {
    :입력: {text}, {example}
     함수: get_drawings_short()
     모델: gpt-5.2
     역할: 도면 설명 → 도면의 간단한 설명 작성;
  }
else (no)
endif

if (§3 구성요소 참조번호 목록 있음?) then (yes)
  :§3 목록을 P8 {drawings}에 직접 주입;
else (no / 신규 발명)
  partition "P_REF — 구성요소·부호 매핑  〔신규〕" {
    :입력: {claim_text} 전체 청구항
           {drawings} 도면의 간단한 설명
     역할: ① 청구항+도면설명에서 구성요소 추출
           ② 도면설명 명시 구성(컨디셔너 등)도 포함
           ③ 일관된 참조번호 부여
     출력: <구성요소_부호_목록>
           <도면별_구성요소>;
  }
  note right
    ~800tok / 저비용
    F4 부호 일치를 위한 전처리
    → P8 {drawings}에 목록 추가 주입
  end note
endif

partition "Prompt 7 — Spec Description  〔청구항별 병렬〕" {
  :입력: {claim_number}, {claim_text}
         ← ¶ 분리된 전체 청구항 순회
   함수: get_specification_description()
   모델: gpt-5.2
   역할: 청구항별 Clarity·Support·Enablement 보완;
}

partition "Prompt 8 — Spec Embodiment  〔청구항별 병렬〕" {
  :입력: {claim_text} ← ¶ 분리 전체 청구항 순회
         {drawings} ← 도면설명 + P_REF 부호목록
         {output_length} = 700 (운영) / 10,000+ (전체청구항)
         {example}
   함수: get_specification_embodiment()
   모델: gpt-4.1-mini
   역할: 청구항별 실시예 생성;
}
note right
  F1: 독립항+종속항 전수 반영
  F2: 측정→동작 제어흐름
  F3: 도면 누락 없음
  F4: P_REF 부호 그대로 사용
end note

|출력|
:명세서 전체 반환;
stop
@enduml
