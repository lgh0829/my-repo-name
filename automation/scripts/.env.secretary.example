# Secretary Agent 환경 변수
# 이 파일을 복사하여 .env.secretary 로 저장하고 값을 채우세요.
# cp .env.secretary.example .env.secretary

# Anthropic API (필수)
ANTHROPIC_API_KEY=sk-ant-...

# Jira 연동 (선택 — 없으면 스케줄 기능만 사용)
JIRA_BASE_URL=https://patsol.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_DEFAULT_PROJECT=PS

# 하루 작업 가능 시간 (기본 6시간)
WORK_HOURS_PER_DAY=6
